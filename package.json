{
  "name": "sbstnbgdn.com",
  "private": true,
  "type": "module",
  "version": "2.0.0",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "typecheck": "astro check",
    "canonicalise": "bun scripts/canonicalise.ts",
    "lint": "eslint --cache .",
    "lint:fix": "eslint --cache --fix . && bun run canonicalise",
    "knip": "knip-bun",
    "format:check": "prettier --check .",
    "format:write": "prettier --write .",
    "check": "bun run lint:fix && bun run typecheck && bun run knip",
    "verify": "bun run lint:fix && bun run typecheck && bun run format:write && bun run knip && bun run build"
  },
  "dependencies": {
    "@astrojs/sitemap": "3.7.3",
    "@tailwindcss/vite": "4.3.1",
    "astro": "7.0.0",
    "tailwindcss": "4.3.1"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.9",
    "@tailwindcss/node": "4.3.1",
    "eslint": "10.5.0",
    "eslint-plugin-astro": "2.0.0",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "knip": "6.18.0",
    "prettier": "3.8.4",
    "prettier-plugin-astro": "0.14.1",
    "prettier-plugin-tailwindcss": "0.8.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.62.0"
  }
}
