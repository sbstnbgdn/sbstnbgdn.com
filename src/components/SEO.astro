---
import { defaultDescription, siteName, themeColor } from "../data/site";
import type { PageMetadata } from "../data/site";

const {
  title,
  description = defaultDescription,
  pathname,
  robots,
  includeCanonical = true,
} = Astro.props as PageMetadata;

const canonical =
  includeCanonical && pathname && import.meta.env.SITE
    ? new URL(pathname, import.meta.env.SITE).toString()
    : null;
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>{title}</title>
<meta name="description" content={description} />
<meta name="theme-color" content={themeColor} />
{robots && <meta name="robots" content={robots} />}
{canonical && <link rel="canonical" href={canonical} />}
<meta property="og:type" content="website" />
<meta property="og:site_name" content={siteName} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
{canonical && <meta property="og:url" content={canonical} />}
<meta name="twitter:card" content="summary" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
