---
import { profileLinks } from "../data/site";
import ExternalLink from "./ExternalLink.astro";
import ProfilePicture from "./ProfilePicture.astro";
---

<header
  role="banner"
  class="sticky top-0 z-10 flex min-h-min w-full flex-col items-center justify-center border-b border-neutral-200 bg-zinc-100 py-3 dark:border-neutral-900 dark:bg-zinc-900"
>
  <ProfilePicture />
  <a
    class="hover:text-teal mt-2 text-center landscape:mt-0 md:landscape:mt-2"
    href="/">Sebastian Bogdan</a
  >
  <div class="mt-1.5 flex justify-center space-x-3 lg:space-x-4">
    <ExternalLink
      href={profileLinks.linkedin}
      aria-label="Visit LinkedIn profile"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        height="1.5em"
        viewBox="0 0 448 512"
        class="hover:fill-teal dark:fill-zinc-200"
        ><title>LinkedIn</title><path
          d="M416 32H31.9C14.3 32 0 46.5 0 64.3v383.4C0 465.5 14.3 480 31.9 480H416c17.6 0 32-14.5 32-32.3V64.3c0-17.8-14.4-32.3-32-32.3zM135.4 416H69V202.2h66.5V416zm-33.2-243c-21.3 0-38.5-17.3-38.5-38.5S80.9 96 102.2 96c21.2 0 38.5 17.3 38.5 38.5 0 21.3-17.2 38.5-38.5 38.5zm282.1 243h-66.4V312c0-24.8-.5-56.7-34.5-56.7-34.6 0-39.9 27-39.9 54.9V416h-66.4V202.2h63.7v29.2h.9c8.9-16.8 30.6-34.5 62.9-34.5 67.2 0 79.7 44.3 79.7 101.9V416z"
        ></path></svg
      >
    </ExternalLink>
  </div>
</header>
